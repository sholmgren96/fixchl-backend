# ============================================
# FIXCHL BACKEND — Variables de entorno
# Copia este archivo como .env y completa los valores
# ============================================

# Servidor
PORT=3000
NODE_ENV=development

# JWT — cambia este valor por una cadena larga aleatoria
JWT_SECRET=cambia_esto_por_algo_muy_secreto_123456

# Base de datos SQLite (ruta al archivo)
DB_PATH=./fixchl.db

# Twilio — WhatsApp Business API
# Obtén estas credenciales en console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+56912345678

# URL pública del backend (necesaria para el webhook de Twilio)
# En desarrollo usa ngrok: https://tu-url.ngrok.io
# En producción: https://api.fixchl.cl
PUBLIC_URL=https://tu-url.ngrok.io

# URL de la PWA del técnico (para CORS)
PWA_URL=http://localhost:5173
